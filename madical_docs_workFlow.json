        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  {\n    \"contents\": [\n      {\n        \"role\": \"user\",\n        \"parts\": [\n          {\n            \"text\": `You are an advanced medical AI assistant. Thoroughly analyze the provided medical document text and any attached images (such as charts, scans, or diagrams) to extract structured information. Ensure that you cross-reference visual data with the text so no details are missed.\n\nReturn ONLY a valid JSON object matching this exact schema, with no markdown code blocks or extra text outside the JSON:\n{\n  \"summary\": \"A clear 2-3 sentence clinical summary of the document.\",\n  \"classification\": \"Must be exactly one of: [discharge_summary, lab_result, clinical_note, prescription, general_medical_document]\",\n  \"sentiment\": \"Must be exactly one of: [positive, neutral, negative]\",\n  \"entities\": {\n    \"people\": [\"List of all patient or doctor names mentioned\"],\n    \"organizations\": [\"Hospitals, clinics, or healthcare brands mentioned\"],\n    \"dates\": [\"All relevant admission, test, or signature dates\"],\n    \"medical_terms\": [\"List of medications, conditions, illnesses, or laboratory metrics\"]\n  },\n  \"action_items\": [\"List of specific medical recommendations, follow-ups, or treatment steps required\"],\n  \"confidence_score\": 0.95\n}\n\n[Document Text]:\n${$json.text}`\n          },\n          ...($json.images || []).map(img => ({\n            \"inlineData\": {\n              \"mimeType\": img.mime_type,\n              \"data\": img.data\n            }\n          }))\n        ]\n      }\n    ],\n    \"generationConfig\": {\n      \"temperature\": 0.1,\n      \"responseMimeType\": \"application/json\"\n    }\n  }\n}}",
        "options": {}
