    {
      "parameters": {
        "jsCode": "// קבלת כל השורות שנקראו מהגיליון\nconst rows = typeof items !== 'undefined' ? items : $input.all();\nconst now = new Date();\nconst twentyFourHoursAgo = new Date(now.getTime() - (24 * 60 * 60 * 1000));\n\n// סינון שורות מה-24 שעות האחרונות\nconst recentRows = rows.filter(row => {\n  if (!row.json['Processed At']) return false;\n  const processedDate = new Date(row.json['Processed At']);\n  return processedDate >= twentyFourHoursAgo;\n});\n\n// אם אין מסמכים חדשים, נעצור את ה-Workflow עם הודעה מתאימה\nif (recentRows.length === 0) {\n  return [{ json: { has_data: false, html_report: \"<h3>לא עובדו מסמכים חדשים ב-24 השעות האחרונות.</h3>\" } }];\n}\n\n// בניית טבלת HTML מעוצבת עבור המייל היומי\nlet htmlTable = `\n<table style=\"width:100%; border-collapse: collapse; font-family: Arial, sans-serif;\">\n  <thead>\n    <tr style=\"background-color: #007bff; color: white; text-align: right;\">\n      <th style=\"padding: 10px; border: 1px solid #ddd;\">מזהה מסמך</th>\n      <th style=\"padding: 10px; border: 1px solid #ddd;\">מחלקה</th>\n      <th style=\"padding: 10px; border: 1px solid #ddd;\">רגישות</th>\n      <th style=\"padding: 10px; border: 1px solid #ddd;\">סיכום קצר</th>\n    </tr>\n  </thead>\n  <tbody>\n`;\n\nrecentRows.forEach(row => {\n  const sensitivityColor = row.json['Sensitivity'] === 'confidential' ? 'red' : 'inherit';\n  const sensitivityWeight = row.json['Sensitivity'] === 'confidential' ? 'bold' : 'normal';\n  \n  htmlTable += `\n    <tr style=\"text-align: right;\">\n      <td style=\"padding: 10px; border: 1px solid #ddd; font-size: 11px;\">${row.json['Document ID'] || ''}</td>\n      <td style=\"padding: 10px; border: 1px solid #ddd;\">${row.json['Department'] || ''}</td>\n      <td style=\"padding: 10px; border: 1px solid #ddd; color: ${sensitivityColor}; font-weight: ${sensitivityWeight};\">${row.json['Sensitivity'] || ''}</td>\n      <td style=\"padding: 10px; border: 1px solid #ddd; font-size: 13px;\">${row.json['Summary'] || ''}</td>\n    </tr>\n  `;\n});\n\nhtmlTable += `</tbody></table>`;\n\nreturn [{\n  json: {\n    has_data: true,\n    total_processed: recentRows.length,\n    html_report: `\n      <div dir=\"rtl\">\n        <h2>📊 דוח סיכום יומי - עיבוד מסמכים רפואיים</h2>\n        <p>במהלך 24 השעות האחרונות עובדו בהצלחה <strong>${recentRows.length}</strong> מסמכים במערכת.</p>\n        <hr>\n        ${htmlTable}\n      </div>\n    `\n  }\n}];"
      },
