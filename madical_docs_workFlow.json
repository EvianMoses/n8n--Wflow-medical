      "parameters": {
        "jsCode": "const enrichData = $('HTTP Request (Enrich)').item.json;\nconst geminiRaw = $('HTTP Request (gemini)').item.json.candidates[0].content.parts[0].text;\nconst geminiJson = JSON.parse(geminiRaw);\n\n// יצירת תוכן ה-Markdown\nconst markdownContent = `# דוח עיבוד מסמך רפואי\n**מזהה מסמך:** ${enrichData.document_id}\n**מחלקה:** ${enrichData.department}\n**רמת רגישות:** ${enrichData.sensitivity}\n**תאריך עיבוד:** ${enrichData.processed_at}\n\n## סיכום רפואי\n${geminiJson.summary}\n\n## פעולות לביצוע (Action Items)\n${(geminiJson.action_items || []).map(item => `- ${item}`).join('\\n')}\n`;\n\n// החזרת הנתונים כקבצים בינאריים ש-n8n יודע להעלות\nreturn [\n  {\n    json: {\n      filename_prefix: enrichData.document_id\n    },\n    binary: {\n      markdown_file: {\n        data: Buffer.from(markdownContent, 'utf-8').toString('base64'),\n        mimeType: 'text/markdown',\n        fileName: `${enrichData.document_id}.md`\n      },\n      json_file: {\n        data: Buffer.from(JSON.stringify(enrichData, null, 2), 'utf-8').toString('base64'),\n        mimeType: 'application/json',\n        fileName: `${enrichData.document_id}.json`\n      }\n    }\n  }\n];"
      },
